# ========== 农村跑腿后端 - 环境变量示例 ==========
# 复制为 .env 并按实际值填写。生产环境建议通过云托管/容器编排平台的"环境变量"功能注入，不要把 .env 提交到代码库。

# --- 数据库 ---
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=root
DB_PASSWORD=请改成强密码
DB_NAME=rural_errand

# --- CORS 白名单（逗号分隔），生产环境必填 ---
ALLOWED_ORIGINS=https://m.example.com,https://admin.example.com

# --- 初始超级管理员 ---
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=请改成强密码
INITIAL_ADMIN_NAME=系统管理员
INITIAL_ADMIN_ROLE=super

# --- 腾讯云短信 ---
# 如果不接入短信服务（成本最低方案），把下面 4 项留空，并设置 DISABLE_SMS=true
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
SMS_SDK_APP_ID=
SMS_SIGN_NAME=农村跑腿
SMS_TEMPLATE_ID=

# 是否禁用短信验证（true 时跳过所有短信流程，纯密码注册/登录）
DISABLE_SMS=true

# --- 业务参数 ---
# 平台抽佣比例 0~1，0 表示不抽佣
PLATFORM_COMMISSION_RATE=0

# --- Redis（可选，强烈推荐生产开启） ---
# REDIS_URL=redis://:password@host:6379/0

# --- 其他开关（生产环境务必保持空/0） ---
APP_ENV=production
ENABLE_DEBUG_TOOLS=
ENABLE_PROJECT_DOWNLOAD=
DEMO_MODE=
